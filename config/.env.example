# Copy this file to `config/.env` and fill in the values. `.env` is gitignored.

# --- YouTube Data API v3 (public competitor data) ---
# Create at https://console.cloud.google.com → enable "YouTube Data API v3" → Credentials → API Key.
YOUTUBE_API_KEY=

# --- OAuth (optional: only needed for own-channel YouTube Analytics API) ---
# Create at https://console.cloud.google.com → OAuth 2.0 Client ID → Desktop app.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
